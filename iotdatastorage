pragma solidity ^0.8.18;

contract IoTDataStorage {

    struct HealthData {
        string patientID;
        string metricType;
        string metricValue;
    }

    HealthData[] public records;

    function storeData(
        string memory _patientID,
        string memory _metricType,
        string memory _metricValue
    ) public {
        records.push(
            HealthData(_patientID, _metricType, _metricValue)
        );
    }

    function getData(uint index)
        public
        view
        returns (
            string memory,
            string memory,
            string memory
        )
    {
        HealthData memory d = records[index];
        return (
            d.patientID,
            d.metricType,
            d.metricValue
        );
    }

    function totalRecords()
        public
        view
        returns (uint)
    {
        return records.length;
    }
}
